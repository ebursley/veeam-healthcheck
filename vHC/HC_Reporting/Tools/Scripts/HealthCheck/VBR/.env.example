# SCA drift check credentials - copy to .env (gitignored) and fill in values
# Values here are only used if the env var is not already set (CI secrets win)

# Linux / no-VPN lab
VBR_LAB_PRIMARY=vbr-linux.example.com
VBR_LAB_USER=veeamadmin
VBR_LAB_PASSWORD=changeme

# Windows / VPN-required lab (used as fallback in single-lab mode,
# or as a separate entry in labs-config.json for multi-lab mode)
VBR_LAB_FALLBACK=192.168.20.x
VBR_LAB_WIN_USER=veeamadmin
VBR_LAB_WIN_PASSWORD=changeme

# Optional overrides
# VBR_LAB_PORT=9419
# VBR_LAB_CONNECT_TIMEOUT_SECONDS=5
